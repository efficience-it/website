{
  "ci": {
    "collect": {
      "staticDistDir": "./out",
      "url": [
        "/index.html",
        "/blog.html",
        "/audit-symfony-gratuit.html",
        "/agence-symfony-france.html",
        "/article/coding-conventions.html"
      ]
    },
    "assert": {
      "assertions": {
        "categories:performance": [
          "error",
          {
            "minScore": 0.8
          }
        ],
        "categories:accessibility": [
          "error",
          {
            "minScore": 0.9
          }
        ],
        "categories:seo": [
          "error",
          {
            "minScore": 0.9
          }
        ],
        "categories:best-practices": [
          "warn",
          {
            "minScore": 0.9
          }
        ]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": ".lighthouseci"
    }
  }
}
